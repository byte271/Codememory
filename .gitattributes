# Auto-detect text files and normalize line endings to LF in the repo
* text=auto

# Source code
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=lf
*.css text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.mp4 binary
*.db binary
*.db-shm binary
*.db-wal binary
